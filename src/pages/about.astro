---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const works = await getCollection('works');
const aboutEntry = works.find((w) => w.id === 'about');
const skillEntry = works.find((w) => w.id === 'skill-sheet');
const credEntry = works.find((w) => w.id === 'credentials');

if (!aboutEntry || !skillEntry || !credEntry) {
  throw new Error('Missing work entry');
}

// Level: 1=Touched, 2=Used, 3=Comfortable, 4=Strong, 5=Expert
// 業務経験があるのは Java のみ。それ以外は個人開発レベル = 3 で揃える。
const skillGroups = [
  {
    label: 'Languages',
    items: [
      { name: 'Java', level: 4 },
      { name: 'TypeScript', level: 3 },
      { name: 'JavaScript', level: 3 },
      { name: 'Python', level: 3 },
    ],
  },
  {
    label: 'Frontend',
    items: [
      { name: 'Next.js', level: 3 },
      { name: 'Astro', level: 3 },
      { name: 'React', level: 3 },
      { name: 'Tailwind v4', level: 3 },
      { name: 'shadcn/ui', level: 3 },
    ],
  },
  {
    label: 'Backend / Server',
    items: [
      { name: 'Node.js 20+', level: 3 },
      { name: 'FastAPI', level: 3 },
      { name: 'MCP SDK', level: 3 },
    ],
  },
  {
    label: 'AI',
    items: [
      { name: 'Claude API', level: 4 },
      { name: 'Hugging Face (FLUX)', level: 3 },
      { name: 'Gemini', level: 3 },
      { name: 'OpenAI', level: 3 },
    ],
  },
  {
    label: 'Data & Infra',
    items: [
      { name: 'Oracle', level: 4 },
      { name: 'PostgreSQL', level: 3 },
      { name: 'Neon', level: 3 },
      { name: 'Vercel', level: 3 },
      { name: 'Cloudflare Pages', level: 3 },
      { name: 'GitHub Pages', level: 3 },
    ],
  },
  {
    label: 'Tooling & QA',
    items: [
      { name: 'pnpm', level: 3 },
      { name: 'Playwright', level: 3 },
      { name: 'Vitest', level: 3 },
      { name: 'Stripe', level: 3 },
      { name: 'OAuth', level: 3 },
    ],
  },
];

const LEVEL_LABEL: Record<number, string> = {
  1: 'Touched',
  2: 'Used',
  3: 'Comfortable',
  4: 'Strong',
  5: 'Expert',
};
---

<Layout
  title="About — Haruya Ura"
  description="Liner notes. Profile, skills, and credentials of the maker."
>
  <main class="min-h-screen px-6 py-16 max-w-4xl mx-auto">
    <a
      href="/"
      class="font-mono text-xs text-fg-secondary hover:text-accent-strong transition-colors"
    >
      ← shelf
    </a>

    <header class="mt-12 mb-12">
      <p class="font-mono text-xs text-fg-secondary mb-3 tracking-wider uppercase">
        HU-05 / HU-06 / HU-07 · Liner Notes
      </p>
      <h1 class="font-display text-5xl md:text-6xl text-fg-primary leading-none">
        About
      </h1>
      <p class="font-body text-lg text-fg-secondary mt-3">
        The artist behind the catalogue.
      </p>
    </header>

    <nav class="flex gap-6 mb-16 font-mono text-xs text-fg-secondary tracking-wider uppercase border-t border-b border-border-default py-3">
      <a href="#profile" class="hover:text-accent-strong transition-colors">
        Profile
      </a>
      <a href="#skills" class="hover:text-accent-strong transition-colors">
        Skills
      </a>
      <a href="#credentials" class="hover:text-accent-strong transition-colors">
        Credentials
      </a>
    </nav>

    <section id="profile" class="scroll-mt-12 mb-24">
      <div class="grid md:grid-cols-[200px_1fr] gap-8 items-start">
        <div class="aspect-square overflow-hidden border border-border-default bg-bg-secondary">
          <Image
            src={aboutEntry.data.jacket}
            alt="About jacket"
            width={400}
            height={400}
            class="w-full h-full object-cover"
          />
        </div>

        <div>
          <p class="font-mono text-[10px] text-fg-muted mb-2 tracking-wider uppercase">
            {aboutEntry.data.catalogNumber} · {aboutEntry.data.matrixNumber}
          </p>
          <h2 class="font-display text-3xl text-fg-primary mb-4">Profile</h2>

          <div class="font-body text-base text-fg-primary leading-relaxed space-y-4">
            <p>Engineer / maker.</p>
            <p>
              現職は公共系（自治体・共済・消防）の Java / Oracle システム開発。
              仕事の外側では、業務では触れない領域 — AI applications, modern web,
              Model Context Protocol — を自力で詰めるための作品を作っています。
            </p>
            <p>
              棚の 11 枚は「使える状態まで持っていけるか」を試した記録。小さく完結
              させて、その都度何かを学ぶ。
            </p>
          </div>

          <div class="mt-8">
            <p class="font-mono text-[10px] text-fg-muted mb-2 tracking-wider uppercase">
              Open to
            </p>
            <ul class="font-body text-base text-fg-primary space-y-1">
              <li>· Modern Web エンジニアとしての採用</li>
              <li>· AI 実装の業務委託 / 受託開発</li>
            </ul>
          </div>

          <div class="mt-8 flex flex-col gap-2 font-mono text-xs">
            <a
              href="https://github.com/URA-H"
              class="text-accent-strong hover:underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub: URA-H →
            </a>
            <a
              href="mailto:ft.hu.0418@gmail.com"
              class="text-accent-strong hover:underline"
            >
              ft.hu.0418@gmail.com →
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="skills" class="scroll-mt-12 mb-24">
      <div class="grid md:grid-cols-[200px_1fr] gap-8 items-start">
        <div class="aspect-square overflow-hidden border border-border-default bg-bg-secondary">
          <Image
            src={skillEntry.data.jacket}
            alt="Skill sheet jacket"
            width={400}
            height={400}
            class="w-full h-full object-cover"
          />
        </div>

        <div>
          <p class="font-mono text-[10px] text-fg-muted mb-2 tracking-wider uppercase">
            {skillEntry.data.catalogNumber} · {skillEntry.data.matrixNumber}
          </p>
          <h2 class="font-display text-3xl text-fg-primary mb-4">Skill Sheet</h2>

          <p class="font-body text-base text-fg-secondary mb-4">
            What I reach for when shipping.
          </p>

          <div class="mb-8 flex flex-wrap gap-x-4 gap-y-1 font-mono text-[10px] text-fg-muted tracking-wider uppercase">
            <span><span class="text-fg-primary">●</span>○○○○ Touched</span>
            <span><span class="text-fg-primary">●●</span>○○○ Used</span>
            <span><span class="text-fg-primary">●●●</span>○○ Comfortable</span>
            <span><span class="text-fg-primary">●●●●</span>○ Strong</span>
            <span><span class="text-fg-primary">●●●●●</span> Expert</span>
          </div>

          <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-8">
            {
              skillGroups.map((group) => (
                <div>
                  <dt class="font-mono text-[10px] text-fg-muted mb-3 tracking-wider uppercase">
                    {group.label}
                  </dt>
                  <dd class="space-y-1.5">
                    {group.items.map((item) => (
                      <div class="flex items-baseline justify-between gap-3">
                        <span class="font-body text-sm text-fg-primary">
                          {item.name}
                        </span>
                        <span
                          class="font-mono text-[11px] tracking-[0.25em] shrink-0"
                          aria-label={`${LEVEL_LABEL[item.level]} (${item.level}/5)`}
                        >
                          <span class="text-fg-primary">
                            {'●'.repeat(item.level)}
                          </span>
                          <span class="text-fg-muted">
                            {'○'.repeat(5 - item.level)}
                          </span>
                        </span>
                      </div>
                    ))}
                  </dd>
                </div>
              ))
            }
          </dl>
        </div>
      </div>
    </section>

    <section id="credentials" class="scroll-mt-12 mb-24">
      <div class="grid md:grid-cols-[200px_1fr] gap-8 items-start">
        <div class="aspect-square overflow-hidden border border-border-default bg-bg-secondary">
          <Image
            src={credEntry.data.jacket}
            alt="Credentials jacket"
            width={400}
            height={400}
            class="w-full h-full object-cover"
          />
        </div>

        <div>
          <p class="font-mono text-[10px] text-fg-muted mb-2 tracking-wider uppercase">
            {credEntry.data.catalogNumber} · {credEntry.data.matrixNumber}
          </p>
          <h2 class="font-display text-3xl text-fg-primary mb-4">Credentials</h2>

          <p class="font-body text-base text-fg-secondary italic">
            Coming soon.
          </p>
        </div>
      </div>
    </section>

    <footer
      class="mt-32 border-t border-border-default pt-6 flex justify-between font-mono text-xs text-fg-muted"
    >
      <span>HUR-LINER-NOTES</span>
      <a href="/" class="hover:text-accent-strong transition-colors">
        ← back to shelf
      </a>
    </footer>
  </main>
</Layout>
