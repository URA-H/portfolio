---
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Shelf, { type ShelfWork } from '../components/Shelf';

const works = (await getCollection('works')).sort(
  (a, b) => a.data.order - b.data.order,
);

const shelfData: ShelfWork[] = await Promise.all(
  works.map(async (w) => {
    const optimized = await getImage({
      src: w.data.jacket,
      width: 600,
      height: 600,
      format: 'webp',
    });
    return {
      title: w.data.title,
      catalogNumber: w.data.catalogNumber,
      matrixNumber: w.data.matrixNumber,
      category: w.data.category,
      year: w.data.year,
      shortDescription: w.data.shortDescription,
      href: w.data.href,
      jacketSrc: optimized.src,
    };
  }),
);
---

<Layout>
  <main class="relative h-screen w-screen overflow-hidden">
    {/* Top-left header overlay */}
    <header class="absolute top-5 left-5 z-30 flex gap-1.5">
      <span
        class="border border-border-strong bg-bg-primary px-3 py-1.5 font-mono text-[10px] text-fg-primary tracking-widest uppercase"
      >
        HU RECORDS
      </span>
      <a
        href="/about"
        class="border border-border-default bg-bg-primary/85 backdrop-blur-sm px-3 py-1.5 font-mono text-[10px] text-fg-secondary hover:text-fg-primary tracking-widest uppercase transition-colors"
      >
        About
      </a>
      <a
        href="mailto:ft.hu.0418@gmail.com"
        class="border border-border-default bg-bg-primary/85 backdrop-blur-sm px-3 py-1.5 font-mono text-[10px] text-fg-secondary hover:text-fg-primary tracking-widest uppercase transition-colors"
      >
        Contact
      </a>
    </header>

    {/* The shelf — full canvas */}
    <Shelf works={shelfData} client:load />

    {/* Bottom-right identifier */}
    <footer
      class="absolute bottom-5 right-5 z-30 font-mono text-[10px] text-fg-muted tracking-widest uppercase"
    >
      Haruya Ura · 11 records · 2026
    </footer>

    {/* Bottom-left hint */}
    <p
      class="absolute bottom-5 left-5 z-30 font-mono text-[10px] text-fg-muted tracking-widest uppercase"
    >
      ← drag · scroll · click
    </p>
  </main>
</Layout>

<style is:global>
  html,
  body {
    height: 100%;
    overflow: hidden;
  }
</style>
